# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=        # from @BotFather
TELEGRAM_CHAT_ID=          # target chat ID (use -100 prefix for supergroups)
TELEGRAM_THREAD_ID=        # optional — topic/thread ID for supergroups with topics

# ── Google Sheets ─────────────────────────────────────────────────────────────
ATTENDANCE_SHEET_ID=       # spreadsheet ID from the URL
ATTENDANCE_SHEET_NAME=     # exact tab name, e.g. "Attendance 2026"

OPEN_JIO_DATABASE_SHEET_ID=    # optional — member database spreadsheet ID
OPEN_JIO_DATABASE_SHEET_NAME=  # optional — tab name, e.g. "Database"

# Google credentials — use one of:
#   a) Place credentials.json (service account key) in the project root (local dev)
#      Share your Google Sheet with the service account email first
#   b) Paste the contents of credentials.json here (Railway)
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── Deployment ────────────────────────────────────────────────────────────────
TIMEZONE=Asia/Singapore    # scheduler timezone
# PORT is set automatically by Railway / Cloud Run — do not set it locally
# WEBHOOK_URL=             # your Railway app URL, e.g. https://myapp.up.railway.app
